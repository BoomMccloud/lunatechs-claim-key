# Existing Postgres connection string. The app only creates/uses claim_* tables.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Shared code attendees must enter before requesting an OTP (printed at the venue).
EVENT_ACCESS_CODE=changeme

# Random secret mixed into OTP hashes. Generate: openssl rand -hex 32
OTP_PEPPER=

# Random secret for signing the session cookie. Generate: openssl rand -hex 32
SESSION_SECRET=

# Resend API key (https://resend.com). If unset in development, OTPs are logged to the
# server console instead of emailed.
RESEND_API_KEY=

# Verified Resend sender address.
EMAIL_FROM=Event Keys <keys@yourdomain.com>
